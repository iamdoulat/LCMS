rules_version = '2';

// Firestore Security Rules for Multiple Check In/Out Feature
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(employeeId) {
      return request.auth.uid == employeeId;
    }
    
    function hasRole(role) {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }
    
    function hasAnyRole(roles) {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in roles;
    }
    
    // Multiple Check In/Out Collection
    match /multiple_check_inout/{recordId} {
      // Allow authenticated users to create their own check-in/out records
      allow create: if isAuthenticated() 
                    && request.resource.data.employeeId == request.auth.uid
                    && request.resource.data.keys().hasAll([
                      'employeeId', 'employeeName', 'companyName', 
                      'type', 'timestamp', 'location', 'imageURL', 
                      'remarks', 'createdAt', 'updatedAt'
                    ])
                    && request.resource.data.type in ['Check In', 'Check Out']
                    && request.resource.data.location.keys().hasAll(['latitude', 'longitude']);
      
      // Allow users to read their own records
      // Allow HR/Admin to read all records
      allow read: if isAuthenticated() 
                  && (resource.data.employeeId == request.auth.uid 
                      || hasAnyRole(['Super Admin', 'Admin', 'HR']));
      
      // Prevent updates and deletes for audit trail integrity
      allow update, delete: if false;
    }
    
    // Employees collection (existing - add if not present)
    match /employees/{employeeId} {
      allow read: if isAuthenticated();
      allow write: if hasAnyRole(['Super Admin', 'Admin', 'HR']);
    }
    
    // Users collection (existing - add if not present)
    match /users/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow write: if hasAnyRole(['Super Admin', 'Admin']);
    }
  }
}
